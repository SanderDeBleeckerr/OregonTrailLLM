  "excluded_families": [
    {
      "family": "deepseek-r1",
      "reason": "mandatory <think> reasoning output breaks JSON parsing"
    },
    {
      "family": "qwq / magistral / any 'reasoning' tag",
      "reason": "same thinking-leakage problem"
    },
    {
      "family": "qwen3 / gpt-oss",
      "reason": "usable only with thinking explicitly disabled; excluded from auto-pick for safety"
    }
  ],
  "runtime": {
    "context_trap": "Ollama defaults to num_ctx=4096 regardless of the model's native maximum. The game history reaches ~6-8k tokens by turn 20, so the wizard MUST set num_ctx or early decisions (and party facts) silently fall out of context.",
    "how_to_set": {
      "api": "POST /api/generate with options: {\"num_ctx\": 16384}",
      "env": "OLLAMA_CONTEXT_LENGTH=16384 ollama serve",
      "interactive": "/set parameter num_ctx 16384"
    },
    "game_requirement_tokens": {
      "per_turn_history": 150,
      "system_and_schema": 1500,
      "turns_target": 20,
      "minimum_num_ctx": 8192,
      "comfortable_num_ctx": 16384
    },
    "kv_cache_note": "min_vram_gb includes model weights + KV cache at recommended_num_ctx + ~1 GB runtime overhead. KV cache grows linearly with num_ctx; halve num_ctx to reclaim roughly half the listed kv_cache_gb."
  }
