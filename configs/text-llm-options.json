{
  "schema_version": 1,
  "purpose": "Model catalog for auto-selecting an Ollama model for the LLM game master. All entries are non-thinking models (no <think> leakage) with reliable JSON output.",
  "detection": {
    "nvidia": {
      "command": "nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits",
      "output_unit": "MiB",
      "note": "Returns one line per GPU; take the max. Divide by 1024 for GiB."
    },
    "amd": {
      "command": "rocm-smi --showmeminfo vram --csv",
      "note": "Parse 'VRAM Total Memory (B)' column; bytes."
    },
    "apple_silicon": {
      "command": "sysctl -n hw.memsize",
      "note": "Unified memory in bytes; treat ~65% of total RAM as usable for the model."
    },
    "fallback_question": {
      "prompt": "What GPU do you have?",
      "choices": [
        {
          "label": "No GPU / not sure (CPU only)",
          "assume_vram_gb": 0
        },
        {
          "label": "Entry GPU, 4 GB or less (GTX 1650, laptop iGPU)",
          "assume_vram_gb": 4
        },
        {
          "label": "Mid-range, 6-8 GB (RTX 3060 Ti, 4060)",
          "assume_vram_gb": 8
        },
        {
          "label": "Upper mid-range, 10-12 GB (RTX 3080, 4070)",
          "assume_vram_gb": 12
        },
        {
          "label": "High-end, 16 GB (RTX 4080, 5080)",
          "assume_vram_gb": 16
        },
        {
          "label": "Enthusiast, 24 GB+ (RTX 4090, 5090)",
          "assume_vram_gb": 24
        }
      ]
    }
  },
  "selection_rules": {
    "strategy": "Pick the highest-quality_rank model whose min_vram_gb <= detected VRAM; ties broken by smaller size_gb. Then launch it with options.num_ctx = recommended_num_ctx (never rely on Ollama's 4096 default). If VRAM is within 1 GB of min_vram_gb, halve num_ctx instead of downgrading the model.",
    "headroom_note": "min_vram_gb already includes ~2 GB headroom for KV cache at the game's ~6k-token context.",
    "cpu_fallback_id": "llama32-3b-q4",
    "verify_after_pull": "ollama show <pull_tag> | grep -i quantization",
    "context_floor": "Reject any model whose native_context < game_requirement minimum_num_ctx (8192). All current entries pass; the rule guards future additions."
  },
